# ローカル実行時にコピーして .env として使う（Git にコミットしない）

# GitHub Pages の公開 URL（メール本文に載せる）
PAGES_BASE_URL=https://mtakahashi1150.github.io/univ_info_cursor/

# Gmail SMTP（アプリパスワード推奨）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=your-app-password
# 省略時は SMTP_USER に送信
EMAIL_TO=your.address@gmail.com
